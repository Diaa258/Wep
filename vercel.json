{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/games",
      "destination": "/api/games"
    },
    {
      "source": "/api/games/(.*)",
      "destination": "/api/games"
    },
    {
      "source": "/api/bookings",
      "destination": "/api/bookings"
    },
    {
      "source": "/api/analytics",
      "destination": "/api/analytics"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
